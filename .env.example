# ─── White-label identity ───────────────────────────────────
# Each deployment is a single client. These vars control branding,
# admin credentials, and support contact. Change per client.
BRAND_NAME="Acme Foundation"
BRAND_LOGO_URL="https://assets.example.org/logo.png"
BRAND_PRIMARY_COLOR="#2563eb"
BRAND_SUPPORT_EMAIL="support@example.org"
BRAND_COUNTRY="KE"
BRAND_DEFAULT_CURRENCY="USD"
BRAND_LOCALE="en"

# ─── Initial admin user (seeded on first migrate) ───────────
SEED_ADMIN_EMAIL="admin@example.org"
SEED_ADMIN_PASSWORD="change-me-on-first-login"

# ─── Database (Neon / Postgres) ─────────────────────────────
# Each client gets their own database. Same connection string for both
# URL vars (no role split needed in single-tenant).
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── Auth.js ────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="https://yourdomain.com"
NEXT_PUBLIC_APP_URL="https://yourdomain.com"

# Optional Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Encryption (provider secrets at rest) ──────────────────
# AES-256-GCM key. Generate: openssl rand -base64 32
# Must be distinct per client deployment.
ENCRYPTION_KEY=""

# ─── Mail ───────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_WEBHOOK_SECRET=""
MAIL_FROM="Acme Foundation <no-reply@example.org>"

# ─── Inngest ────────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Payment provider webhook signing secrets ──────────────
# Paste the per-provider dashboard secret into its env var. The
# provider's API keys are entered via the admin UI and encrypted
# at rest with ENCRYPTION_KEY.
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
FLUTTERWAVE_WEBHOOK_HASH=""
MTN_MOMO_CALLBACK_SECRET=""
AIRTEL_MONEY_CALLBACK_SECRET=""
PESAPAL_IPN_ID=""

# ─── Storage (Cloudflare R2 / S3) ───────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# ─── Observability ──────────────────────────────────────────
# Optional — loaded dynamically from instrumentation.ts when set.
SENTRY_DSN=""
SENTRY_ENV="production"
SENTRY_TRACES_SAMPLE_RATE="0.1"
LOG_LEVEL="info"
