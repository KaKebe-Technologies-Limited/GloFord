# ────────────────────────────────────────────────────────────
# Gloford — environment variables
# Copy this file to .env.local and fill in real values.
# ────────────────────────────────────────────────────────────

# ─── Runtime ────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database (Neon) ────────────────────────────────────────
# Pooled connection string for Prisma Client at runtime
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require&pgbouncer=true"
# Direct connection (required by Prisma for migrations)
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# ─── Auth.js ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Inngest ────────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=""
MAIL_FROM="Gloford <no-reply@gloford.org>"

# ─── Storage (Cloudflare R2) ────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="gloford-media"
R2_PUBLIC_URL="https://media.gloford.org"

# ─── Payments ───────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""

# Mobile Money (provider-specific, e.g. MTN MoMo)
MOMO_SUBSCRIPTION_KEY=""
MOMO_API_USER=""
MOMO_API_KEY=""
MOMO_ENV="sandbox"

# ─── Seed ───────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@gloford.org"
SEED_ADMIN_PASSWORD="change-me-on-first-login"
